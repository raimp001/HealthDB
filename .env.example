# HealthDB Environment Variables
# Copy this file to .env and fill in the values

# Database
POSTGRES_DB=healthdb
POSTGRES_USER=healthdb
POSTGRES_PASSWORD=  # REQUIRED: Set a strong password

# Redis
REDIS_PASSWORD=  # REQUIRED: Set a strong password

# Authentication
JWT_SECRET=  # REQUIRED: Generate with `openssl rand -hex 32`

# Data Security
DEIDENTIFICATION_SALT=  # REQUIRED: Generate with `openssl rand -hex 32`

# Environment
ENVIRONMENT=development  # Set to 'production' for production deployments
